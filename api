# ============================================
# FUNCIÓN PARA RECUPERAR CONTEXTO Y GENERAR RESPUESTA CON GROQ
# ============================================
def buscar_contexto(pregunta, vector_store, cross_encoder, k=10, top_n=3):
    """Retorna los fragmentos más relevantes (top_n) y su contexto combinado"""
    docs = vector_store.similarity_search(pregunta, k=k)
    if not docs:
        return None, None
    pairs = [(pregunta, doc.page_content) for doc in docs]
    scores = cross_encoder.predict(pairs)
    sorted_indices = np.argsort(scores)[::-1]
    top_docs = [docs[i] for i in sorted_indices[:top_n]]
    contexto = "\n\n".join([doc.page_content for doc in top_docs])
    fuentes = list({doc.metadata.get("source", "desconocido") for doc in top_docs})
    return contexto, fuentes

