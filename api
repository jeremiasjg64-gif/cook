@st.cache_data
def cargar_imagen(ruta_imagen):
    try:
        img_path = Path(ruta_imagen)
        if img_path.exists():
            with open(img_path, "rb") as f:
                img_data = f.read()
            img_base64 = base64.b64encode(img_data).decode()
            extension = img_path.suffix[1:]
            return f"data:image/{extension};base64,{img_base64}"
        return None
    except:
        return None

@st.cache_data
def cargar_documentos():
    """Carga todos los problemas y soluciones de los TXT desde la RAÍZ"""
    documentos = []
    docs_dir = Path(".")  # ← Cambiado: ahora busca en la raíz
    
    for txt_file in docs_dir.glob("*.txt"):
        try:
            with open(txt_file, 'r', encoding='utf-8') as f:
                contenido = f.read()
            
            patron = r'Problema:\s*(.+?)\s*Solución:\s*(.+?)(?=\n\s*Problema:|\Z)'
            matches = re.findall(patron, contenido, re.IGNORECASE | re.DOTALL)
            
            for problema, solucion in matches:
                documentos.append({
                    'problema': problema.strip(),
                    'solucion': solucion.strip(),
                    'archivo': txt_file.name
                })
            
            if "Direcciones de sedes" in contenido:
                sedes_match = re.search(r'Direcciones de sedes por departamento:\s*\n(.*?)(?=\n\n|\nProblema|\Z)', contenido, re.DOTALL)
                if sedes_match:
                    sedes_texto = sedes_match.group(1).strip()
                    documentos.append({
                        'problema': 'direcciones de sedes',
                        'solucion': sedes_texto,
                        'archivo': txt_file.name
                    })
        except:
            pass
    
    return documentos

