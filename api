# FUNCIÓN RESPONDER CON API (FLUIDA Y COMPLETA)
# ==========================================
def responder_con_api(pregunta: str, historial: list, documentos: list) -> str:
    """Responde usando API - conversación fluida con todo lo de TXT"""
    
    # PRIMERO: Verificar si pregunta por el creador
    if es_pregunta_sobre_creador(pregunta):
        return respuesta_sobre_creador()
    
    if not documentos:
        return responder_solo_txt(pregunta, documentos)
    
    # Construir contexto con documentos
    contexto_docs = ""
    for doc in documentos[:25]:
        contexto_docs += f"Problema: {doc['problema']}\nSolución: {doc['solucion']}\n\n"
    
    # Construir historial
    historial_texto = ""
    if historial and len(historial) > 0:
        historial_texto = "\n--- CONVERSACIÓN ANTERIOR ---\n"
        for msg in historial[-8:]:
            if msg["role"] == "user":
                historial_texto += f"Usuario: {msg['content']}\n"
            else:
                historial_texto += f"Asistente: {msg['content']}\n"
        historial_texto += "---\n"
    
    prompt = f"""Eres un asistente virtual amable, empático y conversacional del programa ENLACES del Ministerio de Educación de El Salvador.

📌 **TEMAS QUE CUBRES (según tus documentos):**
- Cuentas @clases.edu.sv (contraseñas, recuperación, restablecimiento)
- Problemas técnicos de laptops (encendido, batería, cargador, pantalla)
- Recuperación de NIE
- Cuentas de docentes (bloqueo, activación)
- Sedes de atención (San Salvador, Santa Ana, San Miguel) con direcciones exactas
- Números de contacto (teléfono 2990-6000, WhatsApp 7070-9889)
- Soporte técnico en general

🎯 **REGLAS:**
1. Usa SOLO la información del CONTEXTO OFICIAL abajo para datos técnicos
2. Responde TODO lo relacionado con los temas arriba mencionados
3. Si el usuario pregunta sobre algo que NO está en tus documentos, dilo amablemente
4. Mantén una conversación natural, con empatía y usando emojis ocasionalmente 😊
5. No te limites solo a @clases.edu.sv - los laptops, sedes, NIE también son parte de ti

CONTEXTO OFICIAL (información real de ENLACES):
{contexto_docs}

{historial_texto}

Usuario: {pregunta}

Responde de forma natural, amable y usando el contexto oficial para información técnica. Puedes conversar fluidamente:"""
    
    try:
        response = cliente.chat.completions.create(
            model=MODELO,
            messages=[
                {"role": "system", "content": "Eres un asistente amable de ENLACES. Ayudas con cuentas @clases.edu.sv, laptops, sedes, NIE y soporte técnico. Hablas de forma natural y empática."},
                {"role": "user", "content": prompt}
            ],
            temperature=0.8,
            max_tokens=500
        )
        
        return response.choices[0].message.content
        
    except Exception as e:
        if "429" in str(e):
            return responder_solo_txt(pregunta, documentos)
        return responder_solo_txt(pregunta, documentos)

# ==========================================
# FUNCIÓN PRINCIPAL
# ==========================================
def responder(pregunta: str, historial: list, documentos: list) -> str:
    """Elige entre API y TXT"""
    
    try:
        return responder_con_api(pregunta, historial, documentos)
    except Exception as e:
        return responder_solo_txt(pregunta, documentos)

